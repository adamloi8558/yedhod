# --- kodhom database (re-use from monorepo ../../.env) ---
DATABASE_URL=

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- worker tuning (downloader) ---
R2_KEY_PREFIX=clips/fhchannel/
R2_THUMB_PREFIX=clips/fhchannel-thumbs/
LOOP_INTERVAL_SEC=300
MAX_DOWNLOADS_PER_CYCLE=0
JOBS_KEY=internal/fhchannel-jobs.jsonl
# Optional ffmpeg path; default just calls "ffmpeg" on PATH
FFMPEG=ffmpeg

# --- resolver (local) ---
# Pages of /videos to crawl per run
RESOLVE_MAX_PAGES_PER_FEED=50
STOP_AFTER_KNOWN_PAGES=3
# Path to user-data-dir of a logged-in Chromium for Playwright (so the
# resolver inherits your premium session cookies). Defaults to a local
# .state/browser-data that you can seed by running the resolver once
# with HEADLESS=0 and logging in manually.
HEADLESS=1
