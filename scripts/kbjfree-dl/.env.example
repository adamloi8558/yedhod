# Used by BOTH the local resolver (scripts/resolve.ts) and the
# server-side downloader (index.ts).

# --- kodhom database (re-use from monorepo ../../.env) ---
DATABASE_URL=

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- worker tuning (downloader only) ---
R2_KEY_PREFIX=clips/kbjfree/
R2_THUMB_PREFIX=clips/kbjfree-thumbs/
# ระยะเวลาระหว่างรอบ poll job queue (วินาที, default 300 = 5 นาที)
LOOP_INTERVAL_SEC=300
# 0 = ไม่จำกัด (default)
MAX_DOWNLOADS_PER_CYCLE=0
# Parent category ที่ชื่อ/slug มี keyword นี้ → access_level=vip
VIP_CATEGORY_KEYWORD=premium
# R2 key ที่ resolver จะ push jobs ไป และ worker จะ poll
JOBS_KEY=internal/kbjfree-jobs.jsonl

# --- resolver only (rich resolver tuning) ---
# จำนวนหน้าของ /videos ที่ crawl ในแต่ละรอบของ resolver
RESOLVE_MAX_PAGES=3
