# --- kbjfree.com auth ---
KBJ_EMAIL=
KBJ_PASSWORD=

# --- kodhom database (re-use of monorepo ../../.env) ---
DATABASE_URL=

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# --- worker tuning ---
# prefix ของ key ใน R2 bucket
R2_KEY_PREFIX=clips/kbjfree/
# Coolify volume สำหรับเก็บ playwright session
STATE_DIR=/data/state
# ระยะเวลาระหว่างรอบ crawl (วินาที) — default 600 = 10 นาที
LOOP_INTERVAL_SEC=600
# จำนวนหน้าสูงสุดที่ crawl ต่อรอบ (0 = ไม่จำกัด — เดินจนหมดเอง)
MAX_PAGES_PER_CYCLE=0
# หยุด crawl ถ้าเจอ N หน้าติดที่ทุกคลิปอยู่ใน DB แล้ว
STOP_AFTER_KNOWN_PAGES=2
# ชื่อ category ที่จะตั้งเป็น VIP (case-insensitive substring match)
VIP_CATEGORY_KEYWORD=premium
# จำนวน upload concurrent (1 = ปลอดภัยสุด)
CONCURRENT_DOWNLOADS=1
